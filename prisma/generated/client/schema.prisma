generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accountType String   @default("PARTICULAR") // "PARTICULAR" | "AGENCIA" | "ADMINISTRADOR"
  lastName    String?
  phone       String?
  password    String?
  location    String?
  avatar      String?
  description String?
  status      String   @default("ACTIVE") // "ACTIVE" | "SUSPENDED"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  vehicles      Vehicle[]
  agencies      Agency[]
  notifications Notification[]
  favorites     Favorite[]
}

model Agency {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug         String?  @unique
  tradeName    String
  logo         String?
  coverImage   String?
  description  String?
  address      String?
  city         String?
  province     String?
  phone        String?
  whatsapp     String?
  instagram    String?
  facebook     String?
  openingHours String? // Texto o JSON string con los horarios
  website      String?
  status       String   @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vehicles Vehicle[]
  branches Branch[]
}

model Branch {
  id        String   @id @default(uuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  city      String? // Localidad
  province  String? // Provincia
  phone     String?
  manager   String? // Encargado
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  category     String // "auto", "camioneta", "moto", "utilitario", "suv", "otro"
  condition    String  @default("USADO") // "USADO" | "0KM"
  brand        String
  model        String
  version      String?
  year         Int
  mileage      Int
  fuel         String?
  transmission String?
  color        String?
  doors        Int?
  traction     String?
  location     String

  price         Float
  previousPrice Float?
  currency      String  @default("USD")
  description   String?
  equipment     String? // JSON array string of selected equipment

  acceptsTradeIn   Boolean @default(false)
  acceptsFinancing Boolean @default(false)

  status        String    @default("PENDING") // "DRAFT" | "PENDING" | "APPROVED" | "REJECTED" | "PAUSED" | "SOLD"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  approvedAt    DateTime?
  expiresAt     DateTime?
  isHighlighted Boolean   @default(false)

  views          Int @default(0)
  whatsappClicks Int @default(0)
  phoneClicks    Int @default(0)

  images        Image[]
  consultations Consultation[]
  favoritedBy   Favorite[]
}

model Image {
  id        String  @id @default(uuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url       String
  order     Int     @default(0)
  isMain    Boolean @default(false)
}

model Consultation {
  id          String   @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  buyerName   String
  message     String
  contactInfo String
  createdAt   DateTime @default(now())
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  vehicleId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([userId, vehicleId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  type      String   @default("INFO") // "PRICE_DROP", "INFO", "SYSTEM"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Advertisement {
  id       String  @id @default(uuid())
  title    String
  type     String  @default("IMAGE") // "IMAGE" | "VIDEO"
  mediaUrl String
  linkUrl  String?

  // Ubicación
  page    String // 'HOME', 'CATALOGO', 'DETALLE'
  areaKey String // 'HOME_INTERSTITIAL', 'CAT_SIDEBAR', etc.

  // Control
  isActive  Boolean   @default(true)
  startDate DateTime  @default(now())
  endDate   DateTime?

  // Stats
  views  Int @default(0)
  clicks Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
